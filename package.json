{
  "name": "faro-ve",
  "version": "0.1.0",
  "description": "PWA humanitaria · Mapa de Esperanza Venezuela · respuesta terremoto 24-jun-2026",
  "type": "module",
  "license": "AGPL-3.0-or-later",
  "author": "Bleiquel Colina <bleiquelc@gmail.com>",
  "homepage": "https://faro-ve.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/bleiquelcolina/faro-ve.git"
  },
  "bugs": {
    "url": "https://github.com/bleiquelcolina/faro-ve/issues",
    "email": "contacto@faro-ve.com"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "lint": "prettier --check . && eslint .",
    "format": "prettier --write .",
    "db:migrate": "supabase db push",
    "db:reset": "supabase db reset",
    "db:diff": "supabase db diff",
    "seed": "tsx scripts/seed-anchor-places.ts && tsx scripts/seed-organizations.ts",
    "ingest:dry": "tsx scripts/ingest/run.ts --dry",
    "ingest:apply": "tsx scripts/ingest/run.ts --apply",
    "test:ai-budget": "tsx scripts/test-ai-budget.ts",
    "worker:cron-ingest:dev": "cd workers/cron-ingest && wrangler dev --test-scheduled",
    "worker:ai-health:dev": "cd workers/ai-health && wrangler dev --test-scheduled",
    "worker:ai-triage:dev": "cd workers/ai-triage && wrangler dev --test-scheduled",
    "deploy:pages": "wrangler pages deploy .svelte-kit/cloudflare --project-name=faro-ve",
    "deploy:workers": "cd workers/cron-ingest && wrangler deploy && cd ../ai-health && wrangler deploy && cd ../ai-triage && wrangler deploy"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.27.3",
    "@lottiefiles/dotlottie-web": "^0.30.0",
    "@supabase/ssr": "^0.5.1",
    "@supabase/supabase-js": "^2.45.4",
    "browser-image-compression": "^2.0.2",
    "dexie": "^4.0.10",
    "exifr": "^7.1.3",
    "leaflet": "^1.9.4",
    "leaflet.markercluster": "^1.5.3",
    "nanoid": "^5.0.7",
    "workbox-window": "^7.3.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20251001.0",
    "@playwright/test": "^1.48.0",
    "@sveltejs/adapter-cloudflare": "^7.2.9",
    "@sveltejs/kit": "^2.68.0",
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "@tailwindcss/forms": "^0.5.9",
    "@types/leaflet": "^1.9.12",
    "@types/leaflet.markercluster": "^1.5.4",
    "@types/node": "^22.7.5",
    "@types/pg": "^8.20.0",
    "@vite-pwa/sveltekit": "^1.1.0",
    "autoprefixer": "^10.4.20",
    "cheerio": "^1.0.0",
    "eslint": "^9.12.0",
    "pg": "^8.22.0",
    "postcss": "^8.4.47",
    "prettier": "^3.3.3",
    "prettier-plugin-svelte": "^3.2.7",
    "prettier-plugin-tailwindcss": "^0.6.8",
    "robots-parser": "^3.0.1",
    "sharp": "^0.35.2",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.5",
    "tailwindcss": "^3.4.13",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3",
    "vite": "^7.3.6",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^2.1.2",
    "workbox-background-sync": "^7.3.0",
    "workbox-build": "^7.3.0",
    "workbox-precaching": "^7.3.0",
    "workbox-routing": "^7.3.0",
    "workbox-strategies": "^7.3.0",
    "wrangler": "^4.105.0"
  }
}
